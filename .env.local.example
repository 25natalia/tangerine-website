# Copiar a .env.local (gitignorado) y completar según el ambiente.

# Usado desde la fase de SEO en adelante (metadata, canonical, sitemap, OG).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Requerido para que /contact envíe correos de verdad (lib/actions/send-contact-email.ts).
# Se obtiene en resend.com — sin esta variable, el formulario falla de forma
# explícita (estado de error real) en vez de fingir que el mensaje se envió.
RESEND_API_KEY=

# Requerido para que /contact registre cada lead en Google Sheets
# (lib/actions/append-lead-to-sheet.ts), además de enviar el correo. Setup:
# 1. Crear un proyecto en Google Cloud Console y habilitar la Google Sheets API.
# 2. Crear una Service Account, generar una clave JSON.
# 3. Compartir la hoja de destino con el email de la Service Account, como Editor.
# 4. Crear en esa hoja una pestaña llamada "Leads" con encabezados en A1:I1
#    (Fecha, Nombre, Empresa, Email, Teléfono, Presupuesto, Mensaje, URL, UTM).
# GOOGLE_SHEET_ID es el ID en la URL de la hoja: .../spreadsheets/d/{ESTE_ID}/edit
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY va con saltos de línea escapados como \n
# (así es como sale del JSON de la Service Account al pegarlo en una sola línea).
# Sin estas tres variables, el registro en la hoja falla de forma explícita
# (mismo criterio que RESEND_API_KEY) — pero el correo se sigue enviando igual,
# y viceversa: son dos canales independientes.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
